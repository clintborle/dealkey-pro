# DealKey Pro — Environment Variables
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real keys.
#
# IMPORTANT FOR CHROME EXTENSION:
# Chrome extensions cannot read .env files at runtime.
# The values below that are marked [HARDCODE IN settings.js] must be
# copied directly into the constants block at the top of src/settings.js.
# Keep this .env for your own reference only.

# ─── Lemon Squeezy ───────────────────────────────────────────────────────────

# Your Lemon Squeezy API key (from Settings → API)
# [HARDCODE IN settings.js] as LEMON_SQUEEZY_API_KEY
LEMON_SQUEEZY_API_KEY=your_api_key_here

# Your store's numeric ID (visible in Settings → Store URL)
# [HARDCODE IN settings.js] as LEMON_SQUEEZY_STORE_ID
LEMON_SQUEEZY_STORE_ID=your_store_id_here

# The numeric product ID for DealKey Pro (visible in product URL)
# [HARDCODE IN settings.js] as LEMON_SQUEEZY_PRODUCT_ID
LEMON_SQUEEZY_PRODUCT_ID=your_product_id_here

# The full checkout URL users are sent to when clicking "Buy"
# Format: https://[store-slug].lemonsqueezy.com/buy/[variant-id]
# [HARDCODE IN settings.js] as LEMON_SQUEEZY_CHECKOUT_URL
LEMON_SQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/buy/your-variant-id

# Webhook signing secret — only needed if you build a backend webhook handler
# Not used in the Chrome extension directly
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Optional: Future Backend ─────────────────────────────────────────────────

# If you later build a serverless webhook handler (e.g. Vercel edge function),
# these vars would be used there to verify webhook signatures and revoke licenses.
# Not needed for the MVP.

# WEBHOOK_ENDPOINT_URL=https://deal-key.com/api/webhooks/lemonsqueezy
